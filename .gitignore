# build artifacts at the root and in any per-crate workspace (the wasm crate
# builds its own `crates/exav-unpack-wasm/target`)
target/
**/*.rs.bk
Cargo.lock.orig
# downloaded signature DB and built caches (see `make cache`)
/exav-db/
*.cache
*.exavcache
# real-malware corpus must never be committed
/corpus/
*.malware
/yara-x/
# internal strategy notes — never commit
/tmp/
/.claude/
# local secrets (API keys, e.g. MalwareBazaar Auth-Key) — never commit
.env.local
.env*.local
.env
.DS_Store
